{
  "name": "Jamrock — Alertas Automáticas",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 12 * * *"
            }
          ]
        }
      },
      "id": "node-schedule",
      "name": "Diario 9am ART",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.JAMROCK_URL }}/api/alerts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-alerts-secret",
              "value": "={{ $vars.ALERTS_SECRET }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "node-fetch-alerts",
      "name": "Obtener Alertas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-reprocann",
              "leftValue": "={{ $json.reprocann_proximos.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "id": "cond-stock-med",
              "leftValue": "={{ $json.stock_medicinal_bajo.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "id": "cond-stock-com",
              "leftValue": "={{ $json.stock_comercial_bajo.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "id": "cond-caja",
              "leftValue": "={{ $json.diferencias_caja.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "id": "cond-solicitudes",
              "leftValue": "={{ $json.nuevas_solicitudes.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "id": "cond-cuotas",
              "leftValue": "={{ $json.cuotas_pendientes.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "any"
        }
      },
      "id": "node-has-alerts",
      "name": "¿Hay alertas?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst lines = [];\n\nif (data.reprocann_proximos?.length > 0) {\n  lines.push('🪪 *REPROCANN por vencer*');\n  for (const m of data.reprocann_proximos) {\n    const expiry = m.reprocann_expiry;\n    const today = new Date();\n    const exp = new Date(expiry);\n    const days = Math.ceil((exp - today) / (1000 * 60 * 60 * 24));\n    lines.push(`  • ${m.first_name} ${m.last_name} (#${m.member_number}) — vence en ${days} días (${expiry})`);\n  }\n  lines.push('');\n}\n\nif (data.stock_medicinal_bajo?.length > 0) {\n  lines.push('🌿 *Stock medicinal bajo*');\n  for (const s of data.stock_medicinal_bajo) {\n    lines.push(`  • ${s.genetics}: ${s.current_grams}g restantes`);\n  }\n  lines.push('');\n}\n\nif (data.stock_comercial_bajo?.length > 0) {\n  lines.push('🛒 *Stock comercial bajo*');\n  for (const p of data.stock_comercial_bajo) {\n    lines.push(`  • ${p.name}: ${p.stock_quantity} uds (umbral: ${p.low_stock_threshold})`);\n  }\n  lines.push('');\n}\n\nif (data.diferencias_caja?.length > 0) {\n  lines.push('💰 *Diferencias en caja*');\n  for (const c of data.diferencias_caja) {\n    const diff = c.difference > 0 ? `+$${c.difference}` : `-$${Math.abs(c.difference)}`;\n    lines.push(`  • ${c.register_date}: diferencia de ${diff}`);\n  }\n  lines.push('');\n}\n\nif (data.nuevas_solicitudes?.length > 0) {\n  lines.push('📋 *Nuevas solicitudes de ingreso*');\n  for (const s of data.nuevas_solicitudes) {\n    lines.push(`  • ${s.first_name} ${s.last_name} (DNI: ${s.dni})`);\n  }\n  lines.push('');\n}\n\nif (data.cuotas_pendientes?.length > 0) {\n  lines.push(`📅 *Cuotas pendientes: ${data.cuotas_pendientes.length} socio(s)*`);\n  const preview = data.cuotas_pendientes.slice(0, 5);\n  for (const m of preview) {\n    lines.push(`  • ${m.first_name} ${m.last_name} (#${m.member_number}) — $${m.membership_fee}`);\n  }\n  if (data.cuotas_pendientes.length > 5) {\n    lines.push(`  ... y ${data.cuotas_pendientes.length - 5} más`);\n  }\n  lines.push('');\n}\n\nconst header = '🌿 *Jamrock Club — Alertas del día*\\n';\nreturn [{ json: { message: header + lines.join('\\n') } }];"
      },
      "id": "node-build-message",
      "name": "Armar mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 200]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $vars.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.message }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "node-telegram",
      "name": "Enviar Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1120, 200],
      "credentials": {
        "telegramApi": {
          "id": "REEMPLAZAR_CON_TU_CREDENTIAL_ID",
          "name": "Telegram Bot Jamrock"
        }
      }
    },
    {
      "parameters": {},
      "id": "node-no-alerts",
      "name": "Sin alertas",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [900, 440]
    }
  ],
  "connections": {
